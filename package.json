{
  "name": "svg-shards",
  "version": "0.1.0",
  "description": "TypeScript OOP library for working with SVG as independent shards",
  "author": "Leritas <i@leritas.ru>",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leritas/svg-shards.git"
  },
  "bugs": {
    "url": "https://github.com/Leritas/svg-shards/issues"
  },
  "homepage": "https://github.com/Leritas/svg-shards#readme",
  "scripts": {
    "build": "tsc",
    "build:all": "npm run build && npm run build --prefix plugins/svg-highlighter",
    "dev": "tsc --watch",
    "lint": "eslint src tests vitest.config.ts plugins/svg-highlighter/src",
    "lint:fix": "eslint src tests vitest.config.ts plugins/svg-highlighter/src --fix",
    "format": "prettier --write \"**/*.{ts,js,json,md,html,css}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,html,css}\"",
    "prepublishOnly": "npm run build && npm test && npm run lint && npm run format:check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "npm run build:all && node scripts/prepare-demo.mjs && npx serve plugins/svg-highlighter/demo --listen 3000",
    "demo:serve": "node scripts/prepare-demo.mjs && npx serve plugins/svg-highlighter/demo --listen 3000"
  },
  "keywords": [
    "svg",
    "shards",
    "fragments",
    "typescript",
    "graphics",
    "dom",
    "visualization"
  ],
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jsdom": "^24.0.0",
    "prettier": "^3.2.4",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
